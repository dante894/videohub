APP_NAME=VideoHub

HOST=0.0.0.0
PORT=5000

TELEGRAM_TOKEN=

DOWNLOAD_PATH=downloads

DATABASE_URL=sqlite:///videohub.db

FREE_DAILY_LIMIT=3
MAX_VIDEO_HEIGHT=1080
PRO_PRICE_ARS=3000
PRO_DURATION_DAYS=30
TELEGRAM_MAX_FILE_MB=50

MERCADOPAGO_ACCESS_TOKEN=
# Poné acá el dominio público que te da Railway/Render una vez desplegado,
# por ejemplo https://videohub-production.up.railway.app (sin / al final)
PUBLIC_BASE_URL=

# Generá una clave random larga para producción, por ejemplo con:
# python -c "import secrets; print(secrets.token_hex(32))"
FLASK_SECRET_KEY=

# Ruta a un cookies.txt (formato Netscape) exportado de una cuenta real de
# YouTube. Ayuda a esquivar el bloqueo "Sign in to confirm you're not a bot".
# En Render: subilo como "Secret File" y poné acá la ruta que te dé
# (normalmente /etc/secrets/<nombre-del-archivo>).
YTDLP_COOKIES_FILE=

# Proxy opcional para yt-dlp. Formato:
#   http://usuario:contraseña@host:puerto
#   socks5://host:puerto
# Dejalo vacío si no tenés un servicio de proxy contratado.
YTDLP_PROXY=
