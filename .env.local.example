APP_NAME=VideoHub

HOST=0.0.0.0
PORT=5000

TELEGRAM_TOKEN=

DOWNLOAD_PATH=downloads

DATABASE_URL=sqlite:///videohub.db

FREE_DAILY_LIMIT=3
MAX_VIDEO_HEIGHT=1080
PRO_PRICE_ARS=3000
PRO_DURATION_DAYS=30
TELEGRAM_MAX_FILE_MB=50

# Mercado Pago: dejalo vacío si por ahora solo vas a probar las descargas,
# no el cobro del plan PRO.
MERCADOPAGO_ACCESS_TOKEN=
PUBLIC_BASE_URL=http://localhost:5000

FLASK_SECRET_KEY=clave-de-desarrollo-cualquier-cosa

# Sin proxy: tu IP de casa ya sale por tu país real, así que la mayoría
# de los bloqueos "solo disponible en Latinoamérica" no deberían aparecer
# corriendo local.
YTDLP_PROXY=

# Opcional: si YouTube te empieza a pedir "confirmá que no sos un bot"
# incluso desde tu IP de casa, exportá un cookies.txt de tu propia cuenta
# de YouTube (con una extensión como "Get cookies.txt LOCALLY") y poné
# la ruta acá, por ejemplo: YTDLP_COOKIES_FILE=./cookies.txt
YTDLP_COOKIES_FILE=
